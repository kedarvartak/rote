{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rote.local/schemas/benchmark-usage-sidecar.schema.json",
  "title": "Rote benchmark usage sidecar",
  "description": "Provider token usage entries consumed by rote-bench report. Every entry must be tagged with the source that made the LLM call.",
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/$defs/tokenUsage" }
    },
    {
      "type": "object",
      "required": ["token_usage"],
      "additionalProperties": false,
      "properties": {
        "token_usage": {
          "type": "array",
          "items": { "$ref": "#/$defs/tokenUsage" }
        }
      }
    }
  ],
  "$defs": {
    "tokenUsage": {
      "type": "object",
      "required": ["source", "input_tokens", "output_tokens"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": ["planner", "matcher", "slot", "judgment", "repair", "verify", "distill"]
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
