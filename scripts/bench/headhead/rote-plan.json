{
  "runs": [
    {
      "task": {
        "id": "B1",
        "name": "download latest report"
      },
      "phase": "cold",
      "command": "node",
      "args": [
        "packages/cli/bin/rote.js",
        "run",
        "Sign in to the reports portal with username \"analyst\" and password \"s3cret\", then download the latest report.",
        "--url",
        "http://127.0.0.1:8080/b1-report.html",
        "--verify-text",
        "Report download complete: quarterly-report.pdf",
        "--model",
        "claude-opus-4-8"
      ],
      "repetitions": 18
    },
    {
      "task": {
        "id": "B2",
        "name": "vendor registration"
      },
      "phase": "cold",
      "command": "node",
      "args": [
        "packages/cli/bin/rote.js",
        "run",
        "Register a vendor with company name \"Northwind Supply\", contact email \"ap@northwind.test\", tax ID \"84-1129930\", address line 1 \"18 Harbor Way\", city \"Portland\", postal code \"97209\", country \"US\", and phone \"503-555-0148\", then submit the registration.",
        "--url",
        "http://127.0.0.1:8080/b2-vendor-form.html",
        "--verify-text",
        "Vendor registration complete",
        "--model",
        "claude-opus-4-8"
      ],
      "repetitions": 18
    },
    {
      "task": {
        "id": "B3",
        "name": "catalog search extraction"
      },
      "phase": "cold",
      "command": "node",
      "args": [
        "packages/cli/bin/rote.js",
        "run",
        "Search the catalog for \"alpha\" and open the Alpha result.",
        "--url",
        "http://127.0.0.1:8080/b3-catalog.html",
        "--verify-text",
        "Alpha product opened",
        "--model",
        "claude-opus-4-8"
      ],
      "repetitions": 18
    }
  ]
}
