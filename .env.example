# Rote — example environment.
#
#   cp .env.example .env      # .env is gitignored; never commit a real key
#   set -a; source .env; set +a
#
# Nothing auto-loads .env (no dotenv dependency — see CLAUDE.md "no premature
# deps"), so you must source it as above. `set -a` exports every variable to
# child processes, which is what the benchmark driver and `rote run` need.

# ─── LLM provider ────────────────────────────────────────────────────────────
# Which provider the tagged LLM client uses. "openai" (default) or "anthropic".
# Only the matching key is required; Anthropic is always optional unless selected.
ROTE_LLM_PROVIDER=openai

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Browser ─────────────────────────────────────────────────────────────────
# Absolute path to a Chrome/Chromium binary. Leave blank to auto-detect the
# usual install locations; set it if detection fails or you want a pinned build
# (a pinned browser is one less thing that drifts between benchmark runs).
CHROME_PATH=

# ─── Run artifacts ───────────────────────────────────────────────────────────
# Where `.rote/runs/<run_id>/` artifacts are written. Defaults to `.rote`.
ROTE_BASE_DIR=.rote

# ─── Optional: live CDP tests ────────────────────────────────────────────────
# The CDP smoke tests are opt-in because they launch a real browser. Set to 1 to
# include them in `npm test`; leave blank for the deterministic fake-world suite.
ROTE_RUN_CDP_TESTS=

# ─── Optional: recorder / replay smoke scripts ───────────────────────────────
# Only needed by the M3 scripts under `scripts/bench/` that wrap a downstream
# browser MCP server. Not used by `rote run` or the head-to-head benchmark.
ROTE_TARGET_IDENTITY=
ROTE_DOWNSTREAM_COMMAND=
ROTE_DOWNSTREAM_ARGS=

# ─── Set by the benchmark driver — do NOT set these here ─────────────────────
# `rote-bench run` injects these per benchmark cell; setting them by hand would
# make every run in a matrix write to the same run id and overwrite each other:
#   ROTE_RUN_ID, ROTE_TASK_SPEC, ROTE_USAGE_FILE,
#   ROTE_BENCH_TASK, ROTE_BENCH_PHASE, ROTE_BENCH_REPETITION
#
# The benchmark model is NOT an env var on purpose: it is pinned per harness in
# `scripts/bench/headhead/tasks.json` so both harnesses provably run the same
# model (docs/03 fairness rules). Change it there, not here.
